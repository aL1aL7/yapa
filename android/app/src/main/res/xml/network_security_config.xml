<?xml version="1.0" encoding="utf-8"?>
<!--
  YAPA Network Security Config
  - Only HTTPS connections are allowed (no cleartext HTTP)
  - Self-signed certificates are handled at runtime via the opt-in setting
    (HttpClient.badCertificateCallback) — NOT globally trusted here.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
